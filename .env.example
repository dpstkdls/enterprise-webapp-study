# .env.example
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me
POSTGRES_DB=app
POSTGRES_PORT=5432
REDIS_PORT=6379

# 앱 소비용
DATABASE_URL=postgresql://app:change-me@localhost:5432/app
REDIS_URL=redis://localhost:6379

# 인증
BETTER_AUTH_SECRET=$(openssl rand -base64 32 로 생성한 값)
BETTER_AUTH_URL=http://localhost:3000