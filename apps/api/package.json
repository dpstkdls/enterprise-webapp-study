{
	"name": "@ews/api",
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "tsx watch --env-file=../../.env src/server.ts",
		"build": "tsup",
		"start": "node --env-file-if-exists=../../.env dist/server.js",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate"
	},
	"dependencies": {
		"@ews/shared": "workspace:*",
		"@fastify/swagger": "^9.8.1",
		"@fastify/swagger-ui": "^6.1.0",
		"drizzle-orm": "^0.45.2",
		"fastify": "^5.10.0",
		"fastify-plugin": "^6.0.0",
		"fastify-type-provider-zod": "^7.0.0",
		"pg": "^8.22.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@ews/tsconfig": "workspace:*",
		"@testcontainers/postgresql": "^12.0.4",
		"@types/node": "^24.13.3",
		"@types/pg": "^8.20.0",
		"drizzle-kit": "^0.31.10",
		"pino-pretty": "^13.1.3",
		"testcontainers": "^11.14.0",
		"tsup": "^8.5.1",
		"tsx": "^4.23.1",
		"typescript": "~6.0.3",
		"vitest": "^4.1.10"
	}
}
